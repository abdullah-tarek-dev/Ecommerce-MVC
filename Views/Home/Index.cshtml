@model BookDisplayModel

<div class="my-3">

    <form class="row row-cols-lg-auto g-3 align-items-center">

        <!-- 🎯 Genre -->
        <div class="col-12">
            <select class="form-select" id="genreId" name="genreId">
                <option value="">All Genres</option>

                @foreach (var genre in Model.Genres)
                {
                    <option value="@genre.Id" selected="@(genre.Id == Model.GenreId)">
                        @genre.GenreName
                    </option>
                }
            </select>
        </div>

        <!-- 🔍 Search -->
        <div class="col-12">
            <input type="text"
                   class="form-control"
                   id="sterm"
                   name="sterm"
                   value="@Model.sterm"
                   placeholder="Search by title">
        </div>

        <!-- 🔘 Buttons -->
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Search</button>
            <a href="/Home/Index" class="btn btn-outline-dark">Reset</a>
        </div>

    </form>

</div>


<!-- 📚 Books -->
<div class="container mt-4">
    <div class="row g-4">

        @foreach (var book in Model.Books)
        {
            <div class="col-md-3 col-sm-6">

                <div class="card h-100 shadow-sm border-0">

                    <!-- 🖼 Image -->
                    <img src="@(string.IsNullOrEmpty(book.ImageUrl) ? "/images/img.jpg" : book.ImageUrl)"
                         class="card-img-top"
                         style="height:220px; object-fit:cover;" />

                    <!-- 📄 Body -->
                    <div class="card-body d-flex flex-column">

                        <h6 class="card-title fw-bold">@book.BookName</h6>

                        <p class="text-muted mb-1" style="font-size:14px;">
                            @book.GenreName
                        </p>

                        <p class="text-muted mb-2" style="font-size:13px;">
                            by @book.AuthorName
                        </p>

                        <!-- 💰 Price -->
                        <h5 class="text-primary fw-bold mb-3">
                            @book.Price EGP
                        </h5>

                        <!-- 🛒 Button -->
                        <button type="button"
                                onclick="add(@book.Id)"
                                class="btn btn-dark mt-auto w-100">
                            <i class="bi bi-cart"></i> Add To Cart
                        </button>

                    </div>
                </div>

            </div>
        }

    </div>
</div>


@section Scripts {
    <script>

        // ➕ Add To Cart
        async function add(bookId) {
            try {
                const response = await fetch(`/Cart/AddItem?bookId=${bookId}`);

                if (response.status === 401) {
                    // ❗ لو مش لوجن → وديه للوجين
                    window.location.href = "/Identity/Account/Login";
                    return;
                }

                if (response.ok) {
                    const result = await response.json();

                    // 🛒 تحديث الكارت
                    const cartCountEl = document.getElementById("cartCount");
                    if (cartCountEl) {
                        cartCountEl.innerText = result;
                    }

                    // 🔔 Notification
                    showToast("Added to cart ✅");
                }

            } catch (err) {
                console.log(err);
            }
        }

        // 🔔 Toast
        function showToast(message) {
            const toast = document.createElement("div");
            toast.innerText = message;

            toast.style.position = "fixed";
            toast.style.bottom = "20px";
            toast.style.right = "20px";
            toast.style.background = "#000";
            toast.style.color = "#fff";
            toast.style.padding = "10px 20px";
            toast.style.borderRadius = "8px";
            toast.style.zIndex = "9999";

            document.body.appendChild(toast);

            setTimeout(() => toast.remove(), 2000);
        }

    </script>
}